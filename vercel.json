{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://YOUR_RAILWAY_URL/api/:path*" },
    { "source": "/audio/:path*", "destination": "https://YOUR_RAILWAY_URL/audio/:path*" },
    { "source": "/editor/:path*", "destination": "https://YOUR_RAILWAY_URL/editor/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
